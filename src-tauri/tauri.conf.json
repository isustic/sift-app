{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sift",
  "version": "0.1.0",
  "identifier": "com.epp.reporting",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Sift Analytics",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "maximized": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "EPP",
    "shortDescription": "Sales & Reporting App",
    "longDescription": "Sift Analytics - Analyze and aggregate data from XLSX files. Import data, build dynamic reports, and export to Excel.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}